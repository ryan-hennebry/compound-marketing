    E --> F --> G
  end

  subgraph COMPOUND["3) Compounding loop"]
    H["You approve, edit, reject,<br/>or ask follow-up questions"]
    I["Agent records learnings,<br/>preferences, and results"]
    J["Next recommendation is more specific"]
    H --> I --> J
  end

  C --> E
  G --> H
  E -. "Improves next run" .-> J
