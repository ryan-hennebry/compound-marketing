flowchart TB
  subgraph SETUP["1) One-time setup in Claude"]
    A["Paste one command in Terminal"]
    B["Answer onboarding questions:<br/>company, channels,<br/>and company perceptions"]
    C["First recommendation is generated"]
    A --> B --> C
  end

  subgraph CYCLE["2) Recommendation cycle"]
    E["Agent reviews channel metrics<br/>and recent content"]
